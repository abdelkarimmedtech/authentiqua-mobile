/**
 * Firestore Security Rules for Authentiqua Mobile App
 * 
 * Role-Based Access Control:
 * - 'normal': Regular students/users - can only access their own data
 * - 'staff': University staff - can read admin collections (universities, fraud_cases, system_stats, templates)
 * - 'admin': Administrators - can create/update/delete admin collections
 * 
 * Rules Strategy:
 * - All users must be authenticated
 * - Users can only access their own personal data (documents, settings, activity)
 * - Staff and admin users get access to admin dashboard collections
 * - System documents (_system) bypass auth for collection initialization
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }
    
    function isSystem(docId) {
      return docId == '_system';
    }
    
    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data.get('role', 'normal');
    }
    
    function isStaff() {
      let role = getUserRole();
      return isAuthenticated() && (role == 'staff' || role == 'admin');
    }
    
    function isAdmin() {
      let role = getUserRole();
      return isAuthenticated() && role == 'admin';
    }
    
    // ==================== USERS COLLECTION ====================
    // Users can read and modify their own profiles
    // System initialization document can bypass auth
    match /users/{userId} {
      allow read, write: if isSystem(userId);
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if false;
    }
    
    // ==================== DOCUMENTS COLLECTION ====================
    // Users can manage their own documents
    // Staff can read reference documents from their university
    match /documents/{documentId} {
      allow read, write: if isSystem(documentId);
      
      // Users can read their own documents
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      
      // Staff can read reference documents (marked with isReference: true)
      allow read: if isStaff() && resource.data.isReference == true;
      
      // Users can upload documents (create)
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Users can update their own documents
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      // Users can delete their own documents
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
    
    // ==================== ACTIVITY COLLECTION ====================
    // Users can read their own activity logs (append-only)
    match /activity/{activityId} {
      allow read, write: if isSystem(activityId);
      allow read: if isAuthenticated() && isOwner(resource.data.userId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
    
    // ==================== SETTINGS COLLECTION ====================
    // Users can manage their own settings
    match /settings/{userId} {
      allow read, write: if isSystem(userId);
      allow read: if isAuthenticated() && isOwner(userId);
      allow create, update: if isAuthenticated() && isOwner(userId);
      allow delete: if false;
    }
    
    // ==================== ADMIN DASHBOARD COLLECTIONS ====================
    
    // Universities collection
    // Staff and admin can read, only admin can write
    match /universities/{universityId} {
      allow read: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    
    // Fraud cases collection
    // Staff and admin can read, only admin can write
    match /fraud_cases/{caseId} {
      allow read: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    
    // System stats collection
    // Staff and admin can read, only admin can write
    match /system_stats/{statsId} {
      allow read: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    
    // Templates collection
    // Staff and admin can read, only admin can write
    match /templates/{templateId} {
      allow read: if isStaff();
      allow create, update: if isAdmin();
      allow delete: if false;
    }
    
    // Staff data collection
    // Staff can read their own data, admin can read/write all
    match /staff/{staffId} {
      allow read: if isAuthenticated() && (isOwner(staffId) || isAdmin());
      allow create, update: if isAdmin() || (isAuthenticated() && isOwner(staffId));
      allow delete: if false;
    }
    
    // ==================== CATCH-ALL RULE ====================
    // Deny everything not explicitly allowed
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
