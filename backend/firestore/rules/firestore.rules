/**
 * Firestore Security Rules for Authentiqa Mobile App
 *
 * Roles:
 * - USER: can read/write only their own documents and account data
 * - UNIVERSITY_STAFF: can read non-reference documents linked to their university
 * - ADMIN: can read and manage admin dashboard data
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSystem(docId) {
      return docId == '_system';
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getUserRole() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserData().get('role', 'USER')
        : 'USER';
    }

    function getUserUniversity() {
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? currentUserData().get('university', '')
        : '';
    }

    function isAdmin() {
      return isAuthenticated() && (getUserRole() == 'ADMIN' || getUserRole() == 'admin' || getUserRole() == 'Admin');
    }

    function isUniversityStaff() {
      return isAuthenticated() && (
        getUserRole() == 'UNIVERSITY_STAFF'
        || getUserRole() == 'university_staff'
        || getUserRole() == 'University_Staff'
        || getUserRole() == 'STAFF'
        || getUserRole() == 'staff'
        || getUserRole() == 'Staff'
        || isAdmin()
      );
    }

    function isSameUniversity(university) {
      return isUniversityStaff() && university != null && university == getUserUniversity();
    }

    function roleWasNotChanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // ==================== USERS ====================
    match /users/{userId} {
      allow read, write: if isSystem(userId);
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin() || (isOwner(userId) && roleWasNotChanged());
      allow delete: if false;
    }

    // ==================== DOCUMENTS ====================
    match /documents/{documentId} {
      allow read, write: if isSystem(documentId);

      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || isOwner(resource.data.uploadedBy)
        || isSameUniversity(resource.data.university);

      allow create: if isAuthenticated()
        && (
          request.resource.data.userId == request.auth.uid
          || request.resource.data.uploadedBy == request.auth.uid
          || isAdmin()
        );

      allow update: if isAdmin()
        || (
          isAuthenticated()
          && (
            resource.data.userId == request.auth.uid
            || resource.data.uploadedBy == request.auth.uid
          )
        )
        || isSameUniversity(resource.data.university);

      allow delete: if isAdmin()
        || (
          isAuthenticated()
          && (
            resource.data.userId == request.auth.uid
            || resource.data.uploadedBy == request.auth.uid
          )
        );
    }

    // ==================== VERIFICATION RESULTS ====================
    match /verificationResults/{resultId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || isSameUniversity(resource.data.university);
      allow create: if isAuthenticated()
        && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin()
        || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    // ==================== FEEDBACK ====================
    match /feedback/{feedbackId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || isOwner(resource.data.createdBy);
      allow create: if isAuthenticated()
        && (
          request.resource.data.userId == request.auth.uid
          || request.resource.data.createdBy == request.auth.uid
        );
      allow update, delete: if isAdmin();
    }

    // ==================== ACTIVITY ====================
    match /activity/{activityId} {
      allow read: if isAdmin()
        || isOwner(resource.data.userId)
        || isSameUniversity(resource.data.university);
      allow create: if isAuthenticated()
        && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // ==================== SETTINGS ====================
    match /settings/{userId} {
      allow read, write: if isSystem(userId);
      allow read, create, update: if isOwner(userId);
      allow delete: if false;
    }

    // ==================== ADMIN DASHBOARD COLLECTIONS ====================
    match /universities/{universityId} {
      allow read: if isUniversityStaff();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /fraud_cases/{caseId} {
      allow read: if isUniversityStaff();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /system_stats/{statsId} {
      allow read: if isUniversityStaff();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /templates/{templateId} {
      allow read: if isUniversityStaff();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isOwner(staffId) || isAdmin();
      allow create, update: if isAdmin() || isOwner(staffId);
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
